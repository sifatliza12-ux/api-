# Copy this file to .env for local development. On Railway, set these as
# service variables instead — do not commit a real .env.

# --- Required everywhere ---

# Any random long string. Signs and verifies every auth token; the server
# refuses to start without it (see server.js).
JWT_SECRET=

# --- Server ---

# Railway injects PORT automatically — you don't need to set this on
# Railway. Only relevant for local development.
PORT=5000

# development | production. Controls the JWT_SECRET/CORS_ORIGIN checks
# below and Playwright's default headless mode. Railway does not set this
# automatically — set it to `production` yourself as a service variable.
NODE_ENV=development

# --- CORS (production only) ---

# Comma-separated list of allowed origins, e.g. the extension's own
# chrome-extension://<id> origin once you know its id. Required in
# production — with NODE_ENV=production and this unset, the API rejects
# every cross-origin request rather than allowing any origin through.
# Not needed in development, where CORS is unrestricted by default.
CORS_ORIGIN=

# --- Playwright / workflow replay ("Run API") ---

# true | false. Controls whether the replay browser is visible. Defaults to
# headless automatically when NODE_ENV=production (Railway has no display),
# and to visible in local development. Set explicitly to override either
# way; usually you don't need to set this at all.
FORGEFLOW_HEADLESS=

# --- Database persistence (production only) ---

# Absolute path to a persistent directory for the SQLite database file.
# Railway's filesystem is wiped on every deploy/restart unless the database
# lives on a mounted Volume — set this to that Volume's mount path (see
# README.md's Railway deployment steps). Leave unset for local development;
# it falls back to backend/data/forgeflow.db as before.
DATABASE_DIR=

# --- Optional ---

# Only needed if you use the Claude-assisted field extraction path; the
# default rule-based parameterizer works without it.
ANTHROPIC_API_KEY=
